{
  "name": "conferences-providers-backend",
  "version": "0.1.0",
  "description": "REST API serving conference/event provider data",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "eval": "promptfoo eval --config tests/evals/get-all-conferences.yaml && promptfoo eval --config tests/evals/get-all-speakers.yaml"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@mistralai/mistralai": "^2.2.5",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.9.1",
    "promptfoo": "^0.121.14",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
